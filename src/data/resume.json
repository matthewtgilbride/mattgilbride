        "title": "Senior Software Engineer",
        "date": "Aug. 2015 - May 2017",
        "icon": {
          "dimensions": {
            "width": 36,
            "height": 36
          },
          "alt": "reuters",
          "copyright": null,
          "url": "https://prismic-io.s3.amazonaws.com/mattgilbride/87d0cf8a-632c-45b4-9a16-4af99c01dcb0_reuters.svg",
